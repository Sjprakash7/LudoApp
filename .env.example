# ---- Backend (`server/.env` — copy from here) ----
PORT=5000
JWT_SECRET=replace-with-long-random-string
NODE_ENV=development

# Optional: first-run bootstrap when no admin exists yet (then remove or rotate)
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=changeme

# Comma-separated extra front-end origins (optional). Defaults include Vercel app in env.js.
# CLIENT_ORIGINS=https://your-preview.vercel.app

# Production guard: set true only if you intentionally need operator REST tooling live
ADMIN_TOOLS_ENABLED=false

# Dev-only: cycles through this list for deterministic dice when not in production
DEBUG_DICE_SEQUENCE=6,3,4,1,5,2

# ---- Frontend (`client/.env`) ----
# During `npm run dev` the Vite dev server proxies `/api/*` to localhost:5000, so these
# can stay empty locally. For production builds, point at your public API/socket origin.
VITE_API_URL=http://localhost:5000
VITE_SOCKET_URL=http://localhost:5000

# Production example (also committed in client/.env.production for this project)
# VITE_API_URL=https://ludoapp.onrender.com
# VITE_SOCKET_URL=https://ludoapp.onrender.com
